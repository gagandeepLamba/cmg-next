# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://root:@localhost:3306/dmconsultant_mydmcons_dm
NODE_ENV=development
PORT=3000

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── Meta / Facebook Lead Ads Integration ─────────────────────────────────────
# From Meta for Developers → Your App → Settings → Basic
META_APP_ID=
META_APP_SECRET=

# Random string you choose; must match what you enter in Meta Webhooks config
META_WEBHOOK_VERIFY_TOKEN=

# Long-lived Page Access Token for the Facebook Page receiving leads
# Generate via Facebook Graph API Explorer or Business Manager
META_PAGE_ACCESS_TOKEN=

# Facebook Page ID that your app is subscribed to
META_PAGE_ID=

# Ad Account ID (without the act_ prefix)
META_AD_ACCOUNT_ID=

# Meta Graph API version (default: v21.0)
META_GRAPH_API_VERSION=v21.0

# CRM endpoint where leads are delivered
META_LEADS_CRM_ENDPOINT=https://cmgone.org/api/web-to-leads

# Integration on/off switch (true/false)
META_INTEGRATION_ENABLED=true

# ── Cron Protection ───────────────────────────────────────────────────────────
# Set this and pass it as "Authorization: Bearer <CRON_SECRET>" when calling cron routes
CRON_SECRET=change-me-to-a-random-cron-secret
